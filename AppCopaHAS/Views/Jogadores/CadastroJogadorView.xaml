<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppCopaHAS.Views.Jogadores.CadastroJogadorView"
             Title="CadastroJogadorView">
    <VerticalStackLayout>
        <Picker Title="---Seleção---" SelectedItem="{Binding SelecaoSelecionada}" ItemsSource="{Binding Selecoes}" ItemDisplayBinding="{Binding Pais}"/>
        <Entry Placeholder="Digite o nome do jogador" 
       Text="{Binding Nome}" />
        <Button Text="Salvar" Command="{Binding SalvarCommand}"></Button>
        <Entry Placeholder="Digite a posição do jogador" 
       Text="{Binding Posicao}" />
        <Entry Placeholder="Número da camisa" 
       Text="{Binding NumeroCamisa}" 
       Keyboard="Numeric" />
    </VerticalStackLayout>
</ContentPage>